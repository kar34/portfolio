---
interface Props {
  title?: string;
  hideFooter?: boolean;
}

const { title = 'Kenny Raymond - Product Designer', hideFooter = false } = Astro.props;
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>

    <!-- Reveal transition panels — layered color cascade during page swap -->
    <div id="reveal-panels" transition:persist aria-hidden="true">
      <div class="reveal-layer" data-color="purple"></div>
      <div class="reveal-layer" data-color="yellow"></div>
      <div class="reveal-layer" data-color="blue"></div>
      <div class="reveal-layer" data-color="black"></div>
    </div>

    <!-- Custom cursor (desktop only) -->
    <div id="cursor" transition:persist aria-hidden="true"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-[8vw] py-5">
      <a href="/" aria-label="Home">
        <img src="/white.png" alt="KR" class="h-11 w-auto" />
      </a>

      <!-- Hamburger menu button — white pill with two lines -->
      <button id="menu-toggle" aria-label="Toggle menu" class="relative z-50 bg-white rounded-full px-4 py-3.5 cursor-pointer">
        <svg width="28" height="12" viewBox="0 0 28 12" xmlns="http://www.w3.org/2000/svg">
          <line id="line-top" x1="4.5" y1="2" x2="23.5" y2="2" stroke="black" stroke-width="2.5" stroke-linecap="round" />
          <line id="line-bottom" x1="4.5" y1="10" x2="23.5" y2="10" stroke="black" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </button>
    </nav>

    <!-- Menu overlay -->
    <div id="menu-overlay" class="fixed inset-0 bg-black z-40 flex flex-col items-center justify-center gap-16 md:gap-16 opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out">
      <a href="/" class="text-white text-5xl md:text-[5.625rem] font-medium opacity-0 translate-y-6 transition-all duration-300 ease-out">Home</a>
      <a href="/work" class="text-white text-5xl md:text-[5.625rem] font-medium opacity-0 translate-y-6 transition-all duration-300 ease-out">Work</a>
      <a href="/about" class="text-white text-5xl md:text-[5.625rem] font-medium opacity-0 translate-y-6 transition-all duration-300 ease-out">About</a>
    </div>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    {!hideFooter && <footer class="bg-black border-t border-neutral-800 py-12 px-6 md:px-10 flex flex-col items-center text-center">
      <h2 class="text-2xl md:text-5xl font-medium mb-6">Kenny Raymond</h2>
      <div class="flex flex-row gap-8">
        <a
          href="https://www.linkedin.com/in/kennyraymond/"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-1 text-base text-white/80 hover:text-white transition-colors duration-200"
        >
          LinkedIn
          <img src="/Footer Social Arrow.png" alt="" class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
        </a>
        <a
          href="mailto:kennyraymond20@gmail.com"
          class="group flex items-center gap-1 text-base text-white/80 hover:text-white transition-colors duration-200"
        >
          Email
          <img src="/Footer Social Arrow.png" alt="" class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
        </a>
        <a
          href="https://soundcloud.com/dj-m3lodic"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-1 text-base text-white/80 hover:text-white transition-colors duration-200"
        >
          Soundcloud
          <img src="/Footer Social Arrow.png" alt="" class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
        </a>
      </div>
    </footer>}

    <!-- Lenis smooth scroll initialization (Vite bundles this ESM import) -->
    <script>
      import Lenis from 'lenis';
      import 'lenis/dist/lenis.css';

      declare global {
        interface Window {
          __lenis?: Lenis;
          __cursorInit?: boolean;
          __revealInit?: boolean;
        }
      }

      if (!window.__lenis) {
        const lenis = new Lenis({
          lerp: 0.15,
          wheelMultiplier: 1,
        });
        window.__lenis = lenis;

        function raf(time: number) {
          window.__lenis?.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);
      }
    </script>

    <!-- Reveal page transition: Semplice-style cover panel driven by ClientRouter events -->
    <script>
      if (!window.__revealInit) {
        window.__revealInit = true;

        const COVER_MS = 550;
        const UNCOVER_MS = 800;
        const STAGGER_MS = 70;
        const HOLD_MS = 300;
        const EASE = 'cubic-bezier(0.65, 0, 0.35, 1)';
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function getLayers() {
          // Returned in DOM order: purple, yellow, blue, white
          return Array.from(document.querySelectorAll<HTMLElement>('.reveal-layer'));
        }

        function wait(ms: number) {
          return new Promise((r) => window.setTimeout(r, ms));
        }

        // Cover in: layers cascade up with staggered delays. Purple leads,
        // white closes the seal last.
        function coverIn() {
          const layers = getLayers();
          if (layers.length === 0) return Promise.resolve();
          if (prefersReducedMotion) {
            layers.forEach((p) => {
              p.style.transition = 'opacity 160ms ease';
              p.style.transform = 'translateY(0%)';
              p.style.opacity = '1';
            });
            return wait(160);
          }
          layers.forEach((p, i) => {
            p.style.transition = `transform ${COVER_MS}ms ${EASE} ${i * STAGGER_MS}ms`;
            p.style.transform = 'translateY(0%)';
          });
          return wait(COVER_MS + (layers.length - 1) * STAGGER_MS);
        }

        // Uncover: subtler than cover. Only the top charcoal layer slides up
        // and out — the colored layers beneath snap out of view invisibly
        // (they're fully covered by charcoal, so the reset isn't seen).
        function uncover() {
          const layers = getLayers();
          if (layers.length === 0) return Promise.resolve();
          const top = layers[layers.length - 1]; // charcoal
          const others = layers.slice(0, -1);    // purple, yellow, blue

          if (prefersReducedMotion) {
            top.style.transition = 'opacity 180ms ease';
            top.style.opacity = '0';
            others.forEach((p) => {
              p.style.transition = 'none';
              p.style.transform = 'translateY(101%)';
            });
            return wait(180).then(() => {
              top.style.transition = 'none';
              top.style.transform = 'translateY(101%)';
              top.style.opacity = '1';
            });
          }

          // Reset the colored layers instantly while charcoal still covers them
          others.forEach((p) => {
            p.style.transition = 'none';
            p.style.transform = 'translateY(101%)';
          });

          // Slide the charcoal layer up and out
          top.style.transition = `transform ${UNCOVER_MS}ms ${EASE}`;
          top.style.transform = 'translateY(-101%)';

          return wait(UNCOVER_MS + 20).then(() => {
            top.style.transition = 'none';
            top.style.transform = 'translateY(101%)';
          });
        }

        // Intercept preparation: run cover animation in parallel with the fetch,
        // so the swap happens only after BOTH cover + fetch are done.
        document.addEventListener('astro:before-preparation', (event: any) => {
          const originalLoader = event.loader;
          event.loader = async () => {
            await Promise.all([coverIn(), originalLoader()]);
          };
        });

        // After DOM swap: reset scroll, reset body bg color (home page cards mutate it),
        // then hold the panel at full cover for a beat before uncovering.
        document.addEventListener('astro:after-swap', () => {
          window.scrollTo(0, 0);
          window.__lenis?.scrollTo(0, { immediate: true });
          document.body.style.backgroundColor = '';
          window.setTimeout(() => uncover(), HOLD_MS);
        });
      }
    </script>

    <!-- Scroll reveal -->
    <script>
      function initScrollReveal() {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.18 }
        );

        document.querySelectorAll('section:not([data-no-reveal])').forEach((el) => {
          el.classList.add('scroll-reveal');
          revealObserver.observe(el);
        });

        // Disconnect on navigation so we don't leak observers
        document.addEventListener('astro:before-swap', () => revealObserver.disconnect(), { once: true });
      }

      // Runs on initial page load AND after every ClientRouter navigation
      document.addEventListener('astro:page-load', initScrollReveal);
    </script>

    <!-- Custom cursor: smooth-tracking white circle that scales on interactive hover -->
    <script>
      const cursor = document.getElementById('cursor');
      const supportsFinePointer = window.matchMedia('(pointer: fine)').matches;

      if (cursor && supportsFinePointer && !window.__cursorInit) {
        window.__cursorInit = true;
        let targetX = window.innerWidth / 2;
        let targetY = window.innerHeight / 2;
        let currentX = targetX;
        let currentY = targetY;
        let visible = false;

        window.addEventListener('mousemove', (e) => {
          targetX = e.clientX;
          targetY = e.clientY;
          if (!visible) {
            visible = true;
            cursor.classList.add('is-visible');
          }
        });

        window.addEventListener('mouseleave', () => {
          visible = false;
          cursor.classList.remove('is-visible');
        });

        window.addEventListener('mouseenter', () => {
          visible = true;
          cursor.classList.add('is-visible');
        });

        function tick() {
          // Lerp for silky, hollyrankin.com-style follow
          currentX += (targetX - currentX) * 0.2;
          currentY += (targetY - currentY) * 0.2;
          cursor.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) translate(-50%, -50%)`;
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);

        // Grow on interactive targets via event delegation so dynamic DOM works too
        const hoverSelector = 'a, button, [role="button"], input[type="submit"], input[type="button"], label[for], .img-clickable';

        document.addEventListener('mouseover', (e) => {
          const target = e.target as HTMLElement;
          if (target && target.closest && target.closest(hoverSelector)) {
            cursor.classList.add('is-hover');
          }
        });

        document.addEventListener('mouseout', (e) => {
          const target = e.target as HTMLElement;
          if (target && target.closest && target.closest(hoverSelector)) {
            cursor.classList.remove('is-hover');
          }
        });

        // Hide on press, restore on release — subtle, matches premium feel
        window.addEventListener('mousedown', () => cursor.classList.add('is-down'));
        window.addEventListener('mouseup', () => cursor.classList.remove('is-down'));
      }
    </script>

    <!-- Menu toggle script (Vite-bundled) -->
    <script>
      function initMenuToggle() {
        const toggle = document.getElementById('menu-toggle');
        const overlay = document.getElementById('menu-overlay');

        if (toggle && overlay) {
          const links = Array.from(overlay.querySelectorAll('a'));
          let isOpen = false;

          function openMenu() {
            isOpen = true;
            toggle.classList.add('is-open');
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            overlay.classList.add('opacity-100', 'pointer-events-auto');
            links.forEach((link, i) => {
              setTimeout(() => {
                link.classList.remove('opacity-0', 'translate-y-6');
                link.classList.add('opacity-100', 'translate-y-0');
              }, 80 + i * 80);
            });
          }

          function closeMenu() {
            isOpen = false;
            toggle.classList.remove('is-open');
            overlay.classList.remove('opacity-100', 'pointer-events-auto');
            overlay.classList.add('opacity-0', 'pointer-events-none');
            links.forEach((link) => {
              link.classList.remove('opacity-100', 'translate-y-0');
              link.classList.add('opacity-0', 'translate-y-6');
            });
          }

          toggle.addEventListener('click', () => {
            isOpen ? closeMenu() : openMenu();
          });

          // Menu links don't close the menu on click — it stays open as the
          // backdrop while the reveal panel plays. The new page loads with a
          // fresh (closed) menu instance via ClientRouter swap.
        }
      }

      document.addEventListener('astro:page-load', initMenuToggle);
    </script>

  </body>
</html>
