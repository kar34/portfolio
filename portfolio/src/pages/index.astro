---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="pt-28 pb-20 px-6 md:px-10">
    <div class="max-w-4xl mx-auto">

      <!-- Name heading -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold uppercase tracking-tight text-center">
        Kenny Raymond
      </h1>

      <!-- Portrait row: email (desktop) | portrait | icons (desktop) -->
      <div class="flex flex-col items-center mt-6 md:mt-8">
        <div class="flex items-center justify-center gap-6 md:gap-10 w-full">

          <!-- Email link — desktop only -->
          <a
            href="mailto:kennyraymond20@gmail.com"
            class="hidden md:block text-sm text-white/80"
          >
            kennyraymond20@gmail.com
          </a>

          <!-- Circular portrait -->
          <div class="w-24 h-24 md:w-28 md:h-28 rounded-full overflow-hidden flex-shrink-0">
            <img
              src="/b&w ken sm.png"
              alt="Kenny Raymond portrait"
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Social icons — desktop only -->
          <div class="hidden md:flex items-center gap-3">
            <a
              href="https://www.linkedin.com/in/kennyraymond/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <img src="/LinkedIn Logo Icon (1).png" alt="LinkedIn" class="w-5 h-5" />
            </a>
            <a
              href="mailto:kennyraymond20@gmail.com"
              aria-label="Email"
            >
              <img src="/Email Logo Icon (1).png" alt="Email" class="w-5 h-5" />
            </a>
            <a
              href="https://soundcloud.com/dj-m3lodic"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="SoundCloud"
            >
              <img src="/SoundCloud Logo Icon (1).png" alt="SoundCloud" class="w-5 h-5" />
            </a>
          </div>

        </div>
      </div>

      <!-- Title -->
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold uppercase tracking-tight text-center mt-4 md:mt-6">
        Product Designer
      </h2>

      <!-- Location -->
      <p class="text-sm text-white/60 text-center md:text-right mt-2">
        Based in Los Angeles
      </p>

      <!-- Social icons — mobile only -->
      <div class="flex md:hidden items-center justify-center gap-4 mt-4">
        <a
          href="https://www.linkedin.com/in/kennyraymond/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <img src="/LinkedIn Logo Icon (1).png" alt="LinkedIn" class="w-5 h-5" />
        </a>
        <a
          href="mailto:kennyraymond20@gmail.com"
          aria-label="Email"
        >
          <img src="/Email Logo Icon (1).png" alt="Email" class="w-5 h-5" />
        </a>
        <a
          href="https://soundcloud.com/dj-m3lodic"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="SoundCloud"
        >
          <img src="/SoundCloud Logo Icon (1).png" alt="SoundCloud" class="w-5 h-5" />
        </a>
      </div>

    </div>
  </section>

  <!-- About Section -->
  <section class="py-20 md:py-28 px-6 md:px-10">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-8 md:gap-16">

        <h2 class="text-4xl md:text-5xl font-semibold uppercase tracking-tight">
          About
        </h2>

        <p class="text-base md:text-lg leading-relaxed text-white/90 md:max-w-sm md:text-right">
          With 10+ years of experience, I shape product experiences through compelling storytelling and a bias toward building.
        </p>

      </div>
    </div>
  </section>

  <!-- WORK section will be added in plan 02 -->

</Layout>
