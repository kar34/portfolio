---
import Layout from '../layouts/Layout.astro';
import WorkCards from '../components/WorkCards.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="pt-28 pb-16 px-10 md:px-20">

    <!-- Name -->
    <h1 class="text-[clamp(2.5rem,7.5vw,8rem)] font-semibold uppercase tracking-tight leading-none">
      Kenny Raymond
    </h1>

    <!-- Portrait row: email | portrait | social icons — centered and close together -->
    <div class="mt-8 md:mt-10 flex items-center justify-center gap-8 md:gap-10">

      <!-- Email — desktop only -->
      <a
        href="mailto:kennyraymond20@gmail.com"
        class="hidden md:flex items-center text-lg text-white/80"
      >
        kennyraymond20@gmail.com
      </a>

      <!-- Portrait -->
      <div class="w-36 h-36 md:w-40 md:h-40 rounded-full overflow-hidden flex-shrink-0">
        <img
          src="/b&w ken sm.png"
          alt="Kenny Raymond portrait"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Social icons — desktop only -->
      <div class="hidden md:flex items-center gap-5">
        <a
          href="https://www.linkedin.com/in/kennyraymond/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <img src="/LinkedIn Logo Icon (1).png" alt="LinkedIn" class="w-10 h-10" />
        </a>
        <a href="mailto:kennyraymond20@gmail.com" aria-label="Email">
          <img src="/Email Logo Icon (1).png" alt="Email" class="w-10 h-10" />
        </a>
        <a
          href="https://soundcloud.com/dj-m3lodic"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="SoundCloud"
        >
          <img src="/SoundCloud Logo Icon (1).png" alt="SoundCloud" class="w-10 h-10" />
        </a>
      </div>

    </div>

    <!-- Title -->
    <h2 class="text-[clamp(2.5rem,7.5vw,8rem)] font-semibold uppercase tracking-tight leading-none mt-6 md:mt-8">
      Product Designer
    </h2>

    <!-- Location -->
    <p class="text-base text-white/60 text-right mt-3">
      Based in Los Angeles
    </p>

    <!-- Social icons — mobile only -->
    <div class="flex md:hidden items-center justify-center gap-6 mt-6">
      <a
        href="https://www.linkedin.com/in/kennyraymond/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <img src="/LinkedIn Logo Icon (1).png" alt="LinkedIn" class="w-8 h-8" />
      </a>
      <a href="mailto:kennyraymond20@gmail.com" aria-label="Email">
        <img src="/Email Logo Icon (1).png" alt="Email" class="w-8 h-8" />
      </a>
      <a
        href="https://soundcloud.com/dj-m3lodic"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="SoundCloud"
      >
        <img src="/SoundCloud Logo Icon (1).png" alt="SoundCloud" class="w-8 h-8" />
      </a>
    </div>

  </section>

  <!-- About Section -->
  <section class="py-20 md:py-28 px-10 md:px-20">
    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-8 md:gap-16">

      <h2 class="text-5xl md:text-7xl font-semibold uppercase tracking-tight">
        About
      </h2>

      <p class="text-base md:text-lg leading-relaxed text-white/90 md:max-w-xs md:text-right">
        With 10+ years of experience, I shape product experiences through compelling storytelling and a bias toward building.
      </p>

    </div>
  </section>

  <!-- Work Section -->
  <section class="py-20 md:py-28 px-10 md:px-20">
    <h2 class="text-[20vw] font-semibold uppercase tracking-tighter leading-none">
      Work
    </h2>

    <WorkCards />
  </section>

</Layout>
