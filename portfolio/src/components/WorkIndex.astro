---
// Editorial index of projects — table of contents for the cinematic cards
// that follow. Used on both / (home) and /work, above WorkCards.
const projects = [
  { num: '01', name: 'LinkedIn Video',     href: '/project/linkedin-video'     },
  { num: '02', name: 'LinkedIn Reactions', href: '/project/linkedin-reactions' },
  { num: '03', name: 'Nearby Friends',     href: '/project/nearby-friends'     },
];
---

<nav aria-label="Selected work" class="work-index w-full max-w-[80vh] mx-auto px-2 md:px-0">
  <p class="text-xs md:text-sm uppercase tracking-[0.2em] text-white/40 mb-3 md:mb-4">
    Index
  </p>
  {projects.map((p, i) => (
    <a
      href={p.href}
      class:list={[
        'group flex items-center justify-between gap-6 py-5 md:py-7',
        'border-t border-white/15',
        i === projects.length - 1 && 'border-b',
      ]}
    >
      <span class="flex items-baseline gap-5 md:gap-10 min-w-0">
        <span class="text-xs md:text-sm text-white/40 tabular-nums tracking-widest">
          {p.num}
        </span>
        <span class="work-index-name text-2xl md:text-4xl lg:text-5xl font-medium tracking-tight truncate">
          {p.name}
        </span>
      </span>

      <svg
        viewBox="0 0 24 24"
        class="work-index-arrow w-6 h-6 md:w-7 md:h-7 flex-shrink-0 text-white/70"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="9 6 18 6 18 15"></polyline>
      </svg>
    </a>
  ))}
</nav>
